  47:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /* Definitions of ADC hardware constraints delays */
  48:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /* Note: Only ADC peripheral HW delays are defined in ADC LL driver driver,   */
  49:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*       not timeout values:                                                  */
  50:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*       Timeout values for ADC operations are dependent to device clock      */
  51:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*       configuration (system clock versus ADC clock),                       */
  52:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*       and therefore must be defined in user application.                   */
  53:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*       Refer to @ref ADC_LL_EC_HW_DELAYS for description of ADC timeout     */
  54:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*       values definition.                                                   */
  55:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /* Note: ADC timeout values are defined here in CPU cycles to be independent  */
  56:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*       of device clock setting.                                             */
  57:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*       In user application, ADC timeout values should be defined with       */
  58:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*       temporal values, in function of device clock settings.               */
  59:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*       Highest ratio CPU clock frequency vs ADC clock frequency:            */
  60:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*        - ADC clock from synchronous clock with AHB prescaler 512,          */
  61:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*          APB prescaler 16, ADC prescaler 4.                                */
  62:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*        - ADC clock from asynchronous clock (HSI) with prescaler 1,         */
  63:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*          with highest ratio CPU clock frequency vs HSI clock frequency:    */
  64:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*          CPU clock frequency max 56MHz, HSI frequency 16MHz: ratio 4.      */
  65:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /* Unit: CPU cycles.                                                          */
  66:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** #define ADC_CLOCK_RATIO_VS_CPU_HIGHEST          (512UL * 16UL * 4UL)
  67:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** #define ADC_TIMEOUT_DISABLE_CPU_CYCLES          (ADC_CLOCK_RATIO_VS_CPU_HIGHEST * 1UL)
  68:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** #define ADC_TIMEOUT_STOP_CONVERSION_CPU_CYCLES  (ADC_CLOCK_RATIO_VS_CPU_HIGHEST * 1UL)
  69:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /* Note: CCRDY handshake requires 1APB + 2 ADC + 3 APB cycles                 */
  70:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*       after the channel configuration has been changed.                    */
  71:Drivers/STM32G0xx_HAL_Driver/Src/stm32g0xx_ll_adc.c **** /*       Driver timeout is approximated to 6 CPU cycles.                      */
