2683:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   CLEAR_BIT(USARTx->CR2, (USART_CR2_LINEN | USART_CR2_CLKEN));
2684:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   CLEAR_BIT(USARTx->CR3, (USART_CR3_SCEN | USART_CR3_IREN | USART_CR3_HDSEL));
2685:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h **** }
