2656:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *           - CLKEN bit in the USART_CR2 register,
2657:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *           - SCEN bit in the USART_CR3 register,
2658:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *           - IREN bit in the USART_CR3 register,
2659:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *           - HDSEL bit in the USART_CR3 register.
2660:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   * @note   Call of this function is equivalent to following function call sequence :
2661:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *         - Clear LINEN in CR2 using @ref LL_USART_DisableLIN() function
2662:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *         - Clear CLKEN in CR2 using @ref LL_USART_DisableSCLKOutput() function
2663:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *         - Clear SCEN in CR3 using @ref LL_USART_DisableSmartcard() function
2664:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *         - Clear IREN in CR3 using @ref LL_USART_DisableIrda() function
2665:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *         - Clear HDSEL in CR3 using @ref LL_USART_DisableHalfDuplex() function
2666:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   * @note   Other remaining configurations items related to Asynchronous Mode
2667:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *         (as Baud Rate, Word length, Parity, ...) should be set using
2668:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *         dedicated functions
2669:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   * @rmtoll CR2          LINEN         LL_USART_ConfigAsyncMode\n
2670:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *         CR2          CLKEN         LL_USART_ConfigAsyncMode\n
2671:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *         CR3          SCEN          LL_USART_ConfigAsyncMode\n
2672:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *         CR3          IREN          LL_USART_ConfigAsyncMode\n
2673:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   *         CR3          HDSEL         LL_USART_ConfigAsyncMode
2674:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   * @param  USARTx USART Instance
2675:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   * @retval None
2676:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   */
2677:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h **** __STATIC_INLINE void LL_USART_ConfigAsyncMode(USART_TypeDef *USARTx)
2678:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h **** {
2679:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   /* In Asynchronous mode, the following bits must be kept cleared:
2680:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   - LINEN, CLKEN bits in the USART_CR2 register,
2681:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   - SCEN, IREN and HDSEL bits in the USART_CR3 register.
