2836:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h **** {
2837:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   /* In Smartcard mode, the following bits must be kept cleared:
2838:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   - LINEN bit in the USART_CR2 register,
2839:Drivers/STM32G0xx_HAL_Driver/Inc/stm32g0xx_ll_usart.h ****   - IREN and HDSEL bits in the USART_CR3 register.
